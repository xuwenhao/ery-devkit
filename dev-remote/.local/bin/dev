#!/usr/bin/env bash
set -euo pipefail

# ── Remote devcontainer connection tool ──────────────────────────────
# Connects from local Mac to a devcontainer on a remote server,
# with session management for worktree-based parallel development.
#
# Configuration: ~/.config/dev-remote/<profile>.conf

# ── Color output helpers ─────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

info()   { echo -e "${GREEN}ℹ${NC} $*"; }
warn()   { echo -e "${YELLOW}⚠${NC} $*"; }
error()  { echo -e "${RED}✖${NC} $*" >&2; }
header() { echo -e "\n${BOLD}${BLUE}$*${NC}"; }

# ── Profile loading ──────────────────────────────────────────────────

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/dev-remote"
PROFILE=""

# List profile names (excluding example.conf) to stdout, one per line.
list_profile_names() {
    local conf name
    for conf in "$CONFIG_DIR"/*.conf; do
        [ -f "$conf" ] || continue
        name=$(basename "${conf%.conf}")
        [ "$name" = "example" ] && continue
        echo "$name"
    done
}

# Read a single variable from a profile config file without polluting the
# caller's environment. Tilde/$HOME expansion happens via eval echo.
profile_var() {
    local conf="$1" var="$2"
    bash -c '
        '"$var"'=""
        # shellcheck disable=SC1090
        source "$1"
        eval echo "${'"$var"'}"
    ' _ "$conf" 2>/dev/null
}

# Auto-detect a profile based on $PWD.
#   1. walk up from $PWD for a .dev-remote-profile file
#   2. longest-prefix match on DEV_LOCAL_PROJECT_DIR across profiles
#   3. fall back to "default" if default.conf exists
detect_profile() {
    local dir="$PWD"
    while [ "$dir" != "/" ] && [ -n "$dir" ]; do
        if [ -f "$dir/.dev-remote-profile" ]; then
            local name
            name=$(grep -Ev '^[[:space:]]*(#|$)' "$dir/.dev-remote-profile" | head -1 | tr -d '[:space:]')
            if [ -n "$name" ] && [[ "$name" != */* && "$name" != *..* ]]; then
                echo "$name"
                return 0
            fi
        fi
        dir=$(dirname "$dir")
    done

    local best_profile="" best_len=0
    local conf name local_dir path
    for conf in "$CONFIG_DIR"/*.conf; do
        [ -f "$conf" ] || continue
        name=$(basename "${conf%.conf}")
        [ "$name" = "example" ] && continue
        local_dir=$(profile_var "$conf" DEV_LOCAL_PROJECT_DIR) || continue
        [ -z "$local_dir" ] && continue
        for path in $local_dir; do
            [ -z "$path" ] && continue
            path="${path%/}"
            case "$PWD/" in
                "$path"/*)
                    if [ "${#path}" -gt "$best_len" ]; then
                        best_len=${#path}
                        best_profile="$name"
                    fi
                    ;;
            esac
        done
    done
    if [ -n "$best_profile" ]; then
        echo "$best_profile"
        return 0
    fi

    if [ -f "$CONFIG_DIR/default.conf" ]; then
        echo "default"
        return 0
    fi

    return 1
}

no_profile_error() {
    error "Could not determine which dev-remote profile to use."
    echo ""
    echo "  Available profiles:"
    local name any=false
    while IFS= read -r name; do
        [ -z "$name" ] && continue
        any=true
        echo "    $name"
    done < <(list_profile_names)
    if [ "$any" = false ]; then
        echo "    (none — copy $CONFIG_DIR/example.conf to get started)"
    fi
    echo ""
    echo "  Ways to select one:"
    echo "    $(basename "$0") --profile <name>"
    echo "    export DEV_PROFILE=<name>"
    echo "    echo <name> > .dev-remote-profile      (in a project directory)"
    echo "    add DEV_LOCAL_PROJECT_DIR=\"$PWD\" to a profile config"
}

load_profile() {
    local profile="${PROFILE:-${DEV_PROFILE:-}}"
    local auto=false
    if [ -z "$profile" ]; then
        if profile=$(detect_profile); then
            auto=true
        else
            no_profile_error
            exit 1
        fi
    fi
    local conf="$CONFIG_DIR/${profile}.conf"

    if [ ! -f "$conf" ]; then
        error "Profile not found: $conf"
        echo "  Available profiles:"
        list_profile_names | sed 's/^/    /'
        echo ""
        echo "  Create one by copying the example:"
        echo "    cp $CONFIG_DIR/example.conf $CONFIG_DIR/${profile}.conf"
        exit 1
    fi

    # Source config (values override env vars via := default syntax in conf)
    # shellcheck source=/dev/null
    source "$conf"

    # Validate required variables
    : "${DEV_SSH_HOST:?DEV_SSH_HOST not set in profile '$profile'}"
    : "${DEV_CONTAINER_PATTERN:?DEV_CONTAINER_PATTERN not set in profile '$profile'}"
    : "${DEV_CONTAINER_USER:?DEV_CONTAINER_USER not set in profile '$profile'}"
    : "${DEV_WORKSPACE:?DEV_WORKSPACE not set in profile '$profile'}"
    DEV_FORWARD_PORTS="${DEV_FORWARD_PORTS:-}"
    DEV_REMOTE_PROJECT_DIR="${DEV_REMOTE_PROJECT_DIR:-}"
    DEV_LOCAL_PROJECT_DIR="${DEV_LOCAL_PROJECT_DIR:-}"

    PROFILE="$profile"
    if [ "$auto" = true ]; then
        info "Auto-selected profile: $profile"
    fi
}

# ── Usage ────────────────────────────────────────────────────────────

usage() {
    cat <<EOF
Usage: $(basename "$0") [--profile <name>] <command> [options]

Connect to a remote devcontainer with session management.

Commands:
  ssh [host] [options]        SSH to a host shell (default: ai-series)
  codex [path]                Attach Codex in a persistent host session
  claude [path]               Attach Claude in a persistent host session
  connect [name] [options]    Connect to worktree session
                              (default: "main" at project root)
  status                      Show container status, worktrees, and tmux sessions
  sync                        Pull latest main branch on remote
  worktree <name>             Create worktree remotely + connect
  worktree --list             List remote worktrees
  worktree --remove <name>    Remove remote worktree (with safety checks)
  worktree --remove <name> -f Remove remote worktree (skip safety checks)
  scaffold worktree           Deploy generic worktree.sh to remote repo
  list | profiles             List available profiles (marks auto-selected)
  init <name>                 Scaffold a new profile from example.conf

Options:
  --profile <name>            Config profile override
                              Loads ~/.config/dev-remote/<name>.conf
  --ports                     Forward ports via SSH
  --tmux                      Use tmux (split panes/windows, but no graphics
                              protocol passthrough)
  --no-persist                Connect directly without session persistence
  -h, --help                  Show this help message

Profile resolution (first match wins):
  1. --profile <name>
  2. \$DEV_PROFILE environment variable
  3. .dev-remote-profile file in \$PWD or any parent directory
  4. Longest-prefix match of \$PWD against DEV_LOCAL_PROJECT_DIR in a config
  5. default.conf (if it exists)

  Run '$(basename "$0") list' to see profiles and which one matches here.
  Copy the example to create your first profile:
    cp ~/.config/dev-remote/example.conf ~/.config/dev-remote/default.conf

Examples:
  $(basename "$0") ssh                           # Plain SSH to ai-series
  $(basename "$0") codex ~/Codebase/personal/dotfiles
  $(basename "$0") claude ~/Codebase/srpone/zooclaw/ecap-workspace/.worktrees/foo
  $(basename "$0") connect                       # Auto-select profile, attach "main"
  $(basename "$0") connect my-feature            # Attach to "my-feature" session
  $(basename "$0") connect --ports               # Connect with port forwarding
  $(basename "$0") --profile ecap status         # Force "ecap" profile
  $(basename "$0") worktree my-feature           # Create worktree + connect
  $(basename "$0") worktree --list               # List worktrees
  $(basename "$0") sync                          # Pull latest main on remote
  $(basename "$0") list                          # Show all profiles
  $(basename "$0") init myproject                # Scaffold myproject.conf
EOF
}

# ── Helpers ──────────────────────────────────────────────────────────

cmd_ssh() {
    local host="ai-series"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --no-persist)
                shift
                ;;
            -h|--help)
                cat <<EOF
Usage: $(basename "$0") ssh [host]

SSH to a host shell. Defaults to ai-series.
EOF
                return 0
                ;;
            -*)
                error "Unknown ssh option: $1"
                exit 1
                ;;
            *)
                host="$1"
                shift
                ;;
        esac
    done

    exec ssh -t "$host"
}

shell_quote() {
    local value="${1//\'/\'\"\'\"\'}"
    printf "'%s'" "$value"
}

normalize_remote_path() {
    local path="$1"
    if [[ "$path" == "$HOME" ]]; then
        printf '~'
    elif [[ "$path" == "$HOME/"* ]]; then
        printf '~/%s' "${path#"$HOME"/}"
    else
        printf '%s' "$path"
    fi
}

trim_remote_path() {
    local path="$1"
    while [[ "$path" != "/" && "$path" != "~" && "$path" == */ ]]; do
        path="${path%/}"
        [[ -n "$path" ]] || path="/"
    done
    printf '%s' "$path"
}

remote_path_expr() {
    local path="$1"
    if [[ "$path" == "~" ]]; then
        printf '"$HOME"'
    elif [[ "$path" == "~/"* ]]; then
        printf '"$HOME"/%s' "$(shell_quote "${path:2}")"
    else
        shell_quote "$path"
    fi
}

session_slug() {
    local original="$1"
    local path="$1"
    local hash
    [[ "$path" == "~/"* ]] && path="${path:2}"
    path="${path#/}"
    path="${path:-home}"
    if command -v shasum >/dev/null 2>&1; then
        hash="$(printf '%s' "$original" | shasum | awk '{print substr($1, 1, 8)}')"
    elif command -v sha1sum >/dev/null 2>&1; then
        hash="$(printf '%s' "$original" | sha1sum | awk '{print substr($1, 1, 8)}')"
    else
        hash="$(printf '%s' "$original" | cksum | awk '{print $1}')"
    fi
    printf '%s-%s' "${path//[^[:alnum:]._-]/_}" "$hash"
}

cmd_agent() {
    local tool="$1"
    shift
    local host="ai-series"
    local path="${1:-~/Codebase}"
    local session path_expr agent_command

    if [[ $# -gt 1 ]]; then
        error "$tool accepts at most one path"
        exit 1
    fi
    if [[ "$path" == "-h" || "$path" == "--help" ]]; then
        cat <<EOF
Usage: $(basename "$0") $tool [path]

Attach to a persistent $tool session on ai-series.
Defaults to ~/Codebase. Pass a repo or worktree path to keep sessions scoped.
EOF
        return 0
    fi
    if [[ "$path" == -* ]]; then
        error "Unknown $tool option: $path"
        exit 1
    fi

    path="$(trim_remote_path "$(normalize_remote_path "$path")")"
    session="dev-${tool}-$(session_slug "$path")"
    path_expr="$(remote_path_expr "$path")"
    agent_command="zsh -lic \"exec $tool\""

    info "Attaching to $tool session '$session' on $host in $path"
    exec ssh -t "$host" \
        "if command -v tmux >/dev/null 2>&1; then exec tmux new-session -A -s $(shell_quote "$session") -c $path_expr $(shell_quote "$agent_command"); else cd $path_expr || exit; echo 'tmux not found on remote host; falling back to direct $tool' >&2; exec zsh -lic $(shell_quote "exec $tool"); fi"
}

# Find running container, or start it if stopped.
# Sets CONTAINER_ID on success; returns 1 on failure.
dev_find_container() {
    # 1. Look for a running container matching the pattern
    CONTAINER_ID=$(ssh "$DEV_SSH_HOST" \
        "docker ps --filter 'name=$DEV_CONTAINER_PATTERN' --format '{{.ID}}' | head -1" 2>/dev/null)

    if [ -n "$CONTAINER_ID" ]; then
        return 0
    fi

    # 2. Check if a stopped container exists
    local stopped_id
    stopped_id=$(ssh "$DEV_SSH_HOST" \
        "docker ps -a --filter 'name=$DEV_CONTAINER_PATTERN' --format '{{.ID}}' | head -1" 2>/dev/null)

    if [ -n "$stopped_id" ]; then
        # Try starting the existing stopped container first
        info "Container is stopped. Starting..."
        if ssh "$DEV_SSH_HOST" "docker start $stopped_id" >/dev/null 2>&1; then
            :  # started successfully
        else
            # Fallback: recreate via docker compose
            if [ -z "$DEV_REMOTE_PROJECT_DIR" ]; then
                error "Container failed to start and DEV_REMOTE_PROJECT_DIR is not set."
                echo "  Set it in your profile config, e.g.:"
                echo "    DEV_REMOTE_PROJECT_DIR=~/projects/your-project"
                return 1
            fi

            warn "docker start failed, recreating via docker compose..."
            ssh "$DEV_SSH_HOST" \
                "cd $DEV_REMOTE_PROJECT_DIR && docker compose -f .devcontainer/docker-compose.yml up -d" || {
                error "Failed to start container on remote host."
                return 1
            }
        fi

        # Re-fetch the now-running container
        CONTAINER_ID=$(ssh "$DEV_SSH_HOST" \
            "docker ps --filter 'name=$DEV_CONTAINER_PATTERN' --format '{{.ID}}' | head -1" 2>/dev/null)

        if [ -n "$CONTAINER_ID" ]; then
            info "Container started: $CONTAINER_ID"
            return 0
        fi

        error "Container started but could not find it running."
        return 1
    fi

    # 3. No container at all
    error "No container matching '$DEV_CONTAINER_PATTERN' found on $DEV_SSH_HOST."
    echo "  Start the devcontainer on the remote host first, or set DEV_REMOTE_PROJECT_DIR"
    echo "  in your profile for auto-start via docker compose."
    return 1
}

# Run a command inside the remote container
container_run() {
    local workdir="$1"
    shift
    ssh "$DEV_SSH_HOST" \
        "docker exec -u '$DEV_CONTAINER_USER' -w '$workdir' '$CONTAINER_ID' $*"
}

# ── connect ──────────────────────────────────────────────────────────

cmd_connect() {
    local name=""
    local forward_ports=false
    local session_mode="dtach"  # dtach | tmux | none

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --ports) forward_ports=true; shift ;;
            --tmux) session_mode="tmux"; shift ;;
            --no-persist) session_mode="none"; shift ;;
            -*) error "Unknown option: $1"; usage; exit 1 ;;
            *) name="$1"; shift ;;
        esac
    done

    # Determine session name and working directory
    local session_name workdir
    if [ -z "$name" ]; then
        session_name="main"
        workdir="$DEV_WORKSPACE"
    else
        session_name="$name"
        workdir="$DEV_WORKSPACE/.worktrees/$name"
    fi

    # Find or start the container
    dev_find_container || exit 1

    # Validate the working directory exists
    if ! container_run "$DEV_WORKSPACE" test -d "$workdir" 2>/dev/null; then
        error "Directory does not exist in container: $workdir"
        if [ -n "$name" ]; then
            echo "  Create the worktree first: $(basename "$0") worktree $name"
        fi
        exit 1
    fi

    # Build SSH args as an array to avoid eval + string concatenation
    local -a ssh_args=(-t)
    if [ "$forward_ports" = true ]; then
        for port in $DEV_FORWARD_PORTS; do
            ssh_args+=(-L "${port}:localhost:${port}")
        done
        info "Forwarding ports: $DEV_FORWARD_PORTS"
    fi

    # Forward terminal capability env vars so tools like Claude Code
    # can detect the local terminal's image protocol support (iTerm2,
    # Kitty, etc.) even through SSH + docker exec.
    local -a env_args=()
    for var in TERM_PROGRAM TERM_PROGRAM_VERSION COLORTERM KITTY_WINDOW_ID; do
        if [ -n "${!var:-}" ]; then
            env_args+=(-e "${var}=${!var}")
        fi
    done

    # Use kitten ssh when available (Kitty terminal) to preserve graphics
    # protocol support through the SSH tunnel; fall back to plain ssh otherwise.
    local ssh_cmd="ssh"
    if command -v kitten &>/dev/null && [ "${TERM_PROGRAM:-}" = "kitty" ]; then
        ssh_cmd="kitten ssh"
    fi

    local docker_cmd
    case "$session_mode" in
        tmux)
            info "Connecting to tmux session '$session_name' in $workdir"
            docker_cmd="tmux new-session -A -s '$session_name'"
            ;;
        dtach)
            local socket="/tmp/dtach-${session_name}"
            info "Connecting to dtach session '$session_name' in $workdir (graphics passthrough + persist)"
            docker_cmd="dtach -A '$socket' -z bash -l"
            ;;
        none)
            info "Connecting directly (no tmux) to $workdir"
            docker_cmd="exec zsh || exec bash"
            ;;
    esac

    exec $ssh_cmd "${ssh_args[@]}" "$DEV_SSH_HOST" \
        "docker exec -it ${env_args[*]} -u '$DEV_CONTAINER_USER' -w '$workdir' '$CONTAINER_ID' $docker_cmd"
}

# ── status ───────────────────────────────────────────────────────────

cmd_status() {
    header "Remote host: $DEV_SSH_HOST"

    # Check SSH connectivity
    if ! ssh -o ConnectTimeout=5 "$DEV_SSH_HOST" "echo ok" &>/dev/null; then
        error "Cannot connect to $DEV_SSH_HOST"
        exit 1
    fi
    info "SSH connection OK"

    # Container status
    header "Container status"
    local running
    running=$(ssh "$DEV_SSH_HOST" \
        "docker ps --filter 'name=$DEV_CONTAINER_PATTERN' --format 'table {{.ID}}\t{{.Names}}\t{{.Status}}'" 2>/dev/null)

    if [ -n "$running" ]; then
        echo "$running"

        # Find container for further queries
        dev_find_container || return

        # Worktrees
        header "Git worktrees"
        container_run "$DEV_WORKSPACE" git worktree list 2>/dev/null || echo "  (none)"

        # Tmux sessions
        header "Tmux sessions"
        container_run "$DEV_WORKSPACE" tmux list-sessions 2>/dev/null || echo "  (none)"
    else
        warn "No running container matching '$DEV_CONTAINER_PATTERN'"
        echo ""
        echo "  Stopped containers:"
        ssh "$DEV_SSH_HOST" \
            "docker ps -a --filter 'name=$DEV_CONTAINER_PATTERN' --format 'table {{.ID}}\t{{.Names}}\t{{.Status}}'" 2>/dev/null \
            || echo "  (none)"
    fi
}

# ── worktree ─────────────────────────────────────────────────────────

cmd_worktree() {
    if [[ $# -eq 0 ]]; then
        error "worktree requires a name or flag"
        echo "  Usage: $(basename "$0") worktree <name>"
        echo "         $(basename "$0") worktree --list"
        echo "         $(basename "$0") worktree --remove <name>"
        exit 1
    fi

    case "$1" in
        -l|--list)
            dev_find_container || exit 1
            header "Remote worktrees"
            container_run "$DEV_WORKSPACE" git worktree list
            ;;
        -r|--remove)
            local name="${2:-}"
            local force=false
            if [ -z "$name" ]; then
                error "--remove requires a name"
                exit 1
            fi
            if [ "${3:-}" = "--force" ] || [ "${3:-}" = "-f" ]; then
                force=true
            fi
            dev_find_container || exit 1

            # Run safety checks remotely, prompt locally
            if [ "$force" != "true" ]; then
                local check_output
                if check_output=$(container_run "$DEV_WORKSPACE" bash scripts/worktree.sh --no-tmux --check "$name" 2>&1); then
                    info "All safety checks passed."
                else
                    warn "Issues found for worktree '$name':"
                    echo "$check_output"
                    echo ""
                    read -rp "Remove anyway? [y/N] " confirm
                    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
                        info "Aborted."
                        exit 0
                    fi
                fi
            fi

            info "Killing tmux session '$name' (if exists)..."
            container_run "$DEV_WORKSPACE" tmux kill-session -t "$name" 2>/dev/null || true

            info "Removing worktree '$name'..."
            container_run "$DEV_WORKSPACE" bash scripts/worktree.sh --no-tmux --remove "$name" --force
            info "Worktree '$name' removed."
            ;;
        -*)
            error "Unknown worktree option: $1"
            exit 1
            ;;
        *)
            local name="$1"
            shift
            dev_find_container || exit 1

            info "Creating worktree '$name' on remote..."
            container_run "$DEV_WORKSPACE" bash scripts/worktree.sh --no-tmux "$name"

            info "Worktree created. Connecting..."
            cmd_connect "$name" "$@"
            ;;
    esac
}

# ── sync ─────────────────────────────────────────────────────────────

cmd_sync() {
    dev_find_container || exit 1
    header "Syncing main branch on remote"

    # Check for uncommitted changes on main
    local dirty
    dirty=$(container_run "$DEV_WORKSPACE" git status --porcelain 2>&1) || true
    if [ -n "$dirty" ]; then
        warn "Remote workspace has uncommitted changes:"
        echo "$dirty"
        echo ""
        read -rp "Stash changes and continue? [y/N] " confirm
        if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
            info "Aborted."
            exit 0
        fi
        container_run "$DEV_WORKSPACE" git stash
        info "Changes stashed."
    fi

    container_run "$DEV_WORKSPACE" git checkout main
    container_run "$DEV_WORKSPACE" git pull
    info "Remote main branch synced to latest."
}

# ── list / profiles ──────────────────────────────────────────────────

cmd_list() {
    local current="${PROFILE:-${DEV_PROFILE:-}}"
    if [ -z "$current" ]; then
        current=$(detect_profile 2>/dev/null || true)
    fi
    header "dev-remote profiles"
    local any=false
    local conf name host pat local_dir marker
    for conf in "$CONFIG_DIR"/*.conf; do
        [ -f "$conf" ] || continue
        name=$(basename "${conf%.conf}")
        [ "$name" = "example" ] && continue
        any=true
        host=$(profile_var "$conf" DEV_SSH_HOST)
        pat=$(profile_var "$conf" DEV_CONTAINER_PATTERN)
        local_dir=$(profile_var "$conf" DEV_LOCAL_PROJECT_DIR)
        marker="  "
        [ "$name" = "$current" ] && marker="▶ "
        printf "%s%-24s %s@%s\n" "$marker" "$name" "${pat:-?}" "${host:-?}"
        if [ -n "$local_dir" ]; then
            printf "    local: %s\n" "$local_dir"
        fi
    done
    if [ "$any" = false ]; then
        warn "No profiles found in $CONFIG_DIR"
        echo "  Create one with: $(basename "$0") init <name>"
        return
    fi
    echo ""
    if [ -n "$current" ]; then
        info "Current directory → $current"
    else
        warn "Current directory does not match any profile."
    fi
}

# ── init ─────────────────────────────────────────────────────────────

# ── scaffold ────────────────────────────────────────────────────────

cmd_scaffold() {
    if [[ $# -eq 0 ]]; then
        error "scaffold requires a target"
        echo "  Usage: $(basename "$0") scaffold worktree"
        exit 1
    fi

    local target="$1"
    shift

    case "$target" in
        worktree)
            local template_dir="${XDG_CONFIG_HOME:-$HOME/.config}/dev-remote/templates"
            local template="$template_dir/worktree.sh"
            if [ ! -f "$template" ]; then
                error "Template not found: $template"
                echo "  (re-stow the dev-remote package from your dotfiles repo)"
                exit 1
            fi
            dev_find_container || exit 1

            # Ensure scripts/ directory exists on remote
            container_run "$DEV_WORKSPACE" mkdir -p scripts

            # Copy template to remote via stdin
            ssh "$DEV_SSH_HOST" \
                "docker exec -i -u '$DEV_CONTAINER_USER' -w '$DEV_WORKSPACE' '$CONTAINER_ID' \
                bash -c 'cat > scripts/worktree.sh && chmod +x scripts/worktree.sh'" \
                < "$template"

            info "Scaffolded scripts/worktree.sh → $DEV_WORKSPACE/scripts/"

            # Check for setup hook
            if container_run "$DEV_WORKSPACE" test -f scripts/.worktree-setup.sh 2>/dev/null; then
                info "scripts/.worktree-setup.sh found"
            else
                warn "No scripts/.worktree-setup.sh — create one for repo-specific setup"
            fi
            ;;
        *)
            error "Unknown scaffold target: $target"
            echo "  Available: worktree"
            exit 1
            ;;
    esac
}

# ── init ─────────────────────────────────────────────────────────────

cmd_init() {
    local name="${1:-}"
    if [ -z "$name" ]; then
        error "init requires a profile name"
        echo "  Usage: $(basename "$0") init <name>"
        exit 1
    fi
    if [[ "$name" == */* || "$name" == *..* ]]; then
        error "Invalid profile name: $name"
        exit 1
    fi
    local target="$CONFIG_DIR/${name}.conf"
    if [ -e "$target" ]; then
        error "$target already exists"
        exit 1
    fi
    local example="$CONFIG_DIR/example.conf"
    if [ ! -f "$example" ]; then
        error "example.conf not found at $example"
        echo "  (re-stow the dev-remote package from your dotfiles repo)"
        exit 1
    fi
    mkdir -p "$CONFIG_DIR"
    cp "$example" "$target"
    info "Created $target"
    info "Edit it: \${EDITOR:-vi} $target"
}

# ── Main dispatch ────────────────────────────────────────────────────

# Parse global options before command
while [[ $# -gt 0 ]]; do
    case "$1" in
        --profile)
            PROFILE="${2:-}"
            if [ -z "$PROFILE" ]; then
                error "--profile requires a name"
                exit 1
            fi
            shift 2
            ;;
        -h|--help|help)
            usage
            exit 0
            ;;
        -*)
            # Could be a global flag we don't know — stop and let command handle it
            break
            ;;
        *)
            break
            ;;
    esac
done

if [[ $# -eq 0 ]]; then
    usage
    exit 1
fi

COMMAND="$1"
shift

# These commands don't need a profile loaded — handle them first.
case "$COMMAND" in
    ssh)           cmd_ssh "$@"; exit 0 ;;
    codex|claude)  cmd_agent "$COMMAND" "$@"; exit 0 ;;
    list|profiles) cmd_list "$@"; exit 0 ;;
    init)          cmd_init "$@"; exit 0 ;;
esac

# Load profile config before executing command
load_profile

case "$COMMAND" in
    connect)  cmd_connect "$@" ;;
    status)   cmd_status "$@" ;;
    sync)     cmd_sync "$@" ;;
    worktree)  cmd_worktree "$@" ;;
    scaffold)  cmd_scaffold "$@" ;;
    *)
        error "Unknown command: $COMMAND"
        usage
        exit 1
        ;;
esac
